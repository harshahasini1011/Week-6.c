#include <stdio.h>
int main(){
int i,j,rows,cols;
printf("enter no of rows and cols:");
scanf("%d%d",&rows,&cols);
printf("enter matrix a:");
int a[i][j],transpose[j][i];
for(i=0;i<rows;i++){
for(j=0;j<cols;j++){
scanf("%d",&a[i][j]);
}
}
for(i=0;i<rows;i++){
for(j=0;j<cols;j++){
transpose[j][i]=a[i][j];
}
}
for(i=0;i<cols;i++){
for(j=0;j<rows;j++){
printf("%d",transpose[i][j]);
}
printf("\n");
}
return 0;
}
